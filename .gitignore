```gitignore
# =====================================================
# Python
# =====================================================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Python packaging
build/
dist/
*.egg-info/

# =====================================================
# Environment variables & Secrets
# =====================================================
.env
.env.*
*.env

# API Keys / Secrets
secrets.json
credentials.json

# =====================================================
# Airflow
# =====================================================
airflow.db
airflow-webserver.pid

# Airflow logs
logs/
infra/logs/

# Airflow temporary files
*.pid

# =====================================================
# Docker
# =====================================================
docker-compose.override.yml

# =====================================================
# MinIO
# =====================================================
minio_data/
data/

# =====================================================
# MySQL / SQLite
# =====================================================
*.db
*.sqlite
*.sqlite3

# =====================================================
# Jupyter
# =====================================================
.ipynb_checkpoints/

# =====================================================
# VS Code
# =====================================================
.vscode/

# =====================================================
# PyCharm
# =====================================================
.idea/

# =====================================================
# macOS
# =====================================================
.DS_Store

# =====================================================
# Windows
# =====================================================
Thumbs.db
Desktop.ini

# =====================================================
# Logs
# =====================================================
*.log

# =====================================================
# Temporary files
# =====================================================
tmp/
temp/
.cache/

# =====================================================
# Testing
# =====================================================
.pytest_cache/
.coverage
htmlcov/

# =====================================================
# Mypy
# =====================================================
.mypy_cache/

# =====================================================
# Ruff
# =====================================================
.ruff_cache/
```
